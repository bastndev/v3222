{
  "name": "{{projectName}}",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "sparkling-app-cli dev",
    "android": "sparkling-app-cli run:android --skip-copy",
    "run:android": "sparkling-app-cli run:android --skip-copy",
    "build": "sparkling-app-cli build --skip-copy",
    "build:android": "node scripts/build-android.mjs",
    "doctor": "node scripts/doctor.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "tsc --noEmit && vitest run && prettier --check ."
  },
  "dependencies": {
    "@lynx-js/react": "^0.116.2",
    "sparkling-method": "~{{sparklingVersion}}",
    "sparkling-navigation": "{{sparklingVersion}}"
  },
  "devDependencies": {
    "@lynx-js/qrcode-rsbuild-plugin": "^0.4.4",
    "@lynx-js/react-rsbuild-plugin": "^0.12.7",
    "@lynx-js/rspeedy": "^0.13.3",
    "@lynx-js/types": "^3.7.0",
    "@types/react": "^18.3.20",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "sparkling-app-cli": "~{{sparklingVersion}}",
    "sparkling-types": "~{{sparklingVersion}}",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": "^22 || ^24"
  }
}
