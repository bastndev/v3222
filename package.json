{
  "name": "v3222",
  "version": "0.1.0",
  "packageManager": "bun@1.3.4",
  "description": "Create an Android-first Lynx app with live development and native release builds.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "v3222": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist", "template"],
  "sideEffects": false,

  "keywords": ["lynx", "lynxjs", "android", "sparkling", "scaffold", "cli"],
  "author": "Gohit X (bastndev)",
  "license": "MIT",
  "homepage": "https://gohit.xyz/package/v3222",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bastndev/v3222.git"
  },
  "bugs": {
    "url": "https://github.com/bastndev/v3222/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": "^22.18.0 || ^24.0.0"
  },

  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "sparkling-app-template": "2.1.0-rc.33"
  },

  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.5",
    "@types/node": "^22.20.1",
    "publint": "^0.3.21",
    "tsdown": "^0.22.7",
    "typescript": "^7.0.2"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "bun run build && node test/smoke.mjs",
    "check": "bun run typecheck && bun run test",
    "prepack": "bun run check"
  }
}
